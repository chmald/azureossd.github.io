# Enhanced Azure AI Search Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env file to source control

# Azure Search Service Configuration (Required)
AZ_SEARCH_SERVICE_NAME=your-search-service-name
AZ_SEARCH_ADMIN_KEY=your-admin-key-here
AZ_SEARCH_INDEX_NAME=blog-index

# Optional: Query key for read-only operations (recommended for production)
AZ_SEARCH_QUERY_KEY=your-query-key-here

# Environment Configuration
NODE_ENV=development

# Performance Configuration
BATCH_SIZE=100
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Feature Flags
ENABLE_SEMANTIC_SEARCH=false
ENABLE_SUGGESTERS=true
VALIDATE_DOCUMENTS=true

# Content Processing Configuration
MAX_DESCRIPTION_LENGTH=200
MAX_KEYWORDS=10
MIN_KEYWORD_LENGTH=3
EXTRACT_CODE_BLOCKS=true
CALCULATE_READING_TIME=true
